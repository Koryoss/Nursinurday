# =====================================================
# CareFlow 환경 변수 설정 파일
# =====================================================
# 사용법:
#   1. 이 파일을 복사해서 ".env.local" 로 이름 변경
#   2. API 키를 발급받은 후 아래에 입력
#   3. .env.local 은 절대 GitHub에 올리면 안 됩니다! (.gitignore에 이미 추가되어 있음)
# =====================================================

# --- AI API 키 (둘 중 하나만 있어도 됩니다) ---

# OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude API 키 (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# --- AI 모드 설정 ---
# "mock"   → API 키 없이 미리 작성된 간호 응답으로 테스트 (기본값)
# "openai" → OpenAI GPT-4o 사용
# "claude" → Anthropic Claude 사용
AI_MODE=mock
