# 의존성 폴더 (npm install 하면 자동 생성됨)
/node_modules
/.pnp
.pnp.js

# 빌드 결과물
/.next/
/out/
/build

# 환경 변수 (API 키가 담겨 있어서 절대 올리면 안 됨!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 로그
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 에디터 설정
.DS_Store
*.pem
.idea/
.vscode/settings.json

# TypeScript 빌드 캐시
*.tsbuildinfo
next-env.d.ts
